{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "cognitiveProfile": { "type": "string" },
        "archetype": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "blocked"] },
        "xp": { "type": "number" },
        "level": { "type": "number" },
        "coins": { "type": "number" },
        "streak": { "type": "number" },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "JournalEntry": {
      "title": "JournalEntry",
      "description": "A user's journal entry",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "text": { "type": "string" },
        "feedback": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "text", "date", "time", "createdAt"]
    },
    "Post": {
      "title": "Post",
      "description": "A post in the community",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userRole": { "type": "string" },
        "content": { "type": "string" },
        "likes": { "type": "number" },
        "comments": { "type": "number" },
        "pinned": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "userRole", "content", "likes", "comments", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/users/{userId}/journal/{entryId}": {
      "schema": { "$ref": "#/entities/JournalEntry" },
      "description": "User journal entries"
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Community posts"
    }
  }
}
